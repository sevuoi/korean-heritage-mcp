APP_NAME=K-Heritage Guide
APP_ENV=development
LOG_LEVEL=INFO

MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_PATH=/mcp

KAKAO_REST_API_KEY=

HERITAGE_API_LIST_URL=http://www.khs.go.kr/cha/SearchKindOpenapiList.do
HERITAGE_API_DETAIL_URL=http://www.khs.go.kr/cha/SearchKindOpenapiDt.do
HERITAGE_API_TIMEOUT_SECONDS=15
KAKAO_API_TIMEOUT_SECONDS=10

HERITAGE_LIST_CACHE_TTL_SECONDS=21600
HERITAGE_DETAIL_CACHE_TTL_SECONDS=86400
KAKAO_SEARCH_CACHE_TTL_SECONDS=1800

DEFAULT_SEARCH_RADIUS_KM=10
MAX_SEARCH_RADIUS_KM=50
DEFAULT_RESULT_LIMIT=10
MAX_RESULT_LIMIT=20

DEFAULT_TRIP_DAYS=1
DEFAULT_MAX_PLACES_PER_DAY=5
